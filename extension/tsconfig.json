{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "types": ["chrome", "node", "vite/client", "webextension-polyfill"],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "strictFunctionTypes": false,
    "noImplicitReturns": false,
    "noUnusedLocals": false
  },
  "include": ["src/**/*"],
  "exclude": [
    "../scripts/**/*",
    "node_modules",
    "dist",
    "dist-chrome",
    "dist-edge",
    "dist-chromium",
    "dist-firefox"
  ]
}
