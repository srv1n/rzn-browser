{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RZN Extraction Plan v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "mode", "fields"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "mode": { "type": "string", "enum": ["single", "list"] },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "css": { "type": "string", "minLength": 1 },
        "xpath": { "type": "string", "minLength": 1 }
      }
    },
    "item_selector": { "type": "string", "minLength": 1 },
    "limit": { "type": "integer", "minimum": 1, "maximum": 2000 },
    "fields": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "selector"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "selector": { "type": "string", "minLength": 1 },
          "attribute": { "type": "string", "minLength": 1 },
          "optional": { "type": "boolean" }
        }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "mode": { "const": "list" } } },
      "then": { "required": ["item_selector"] }
    },
    {
      "if": { "properties": { "scope": { "type": "object" } } },
      "then": {
        "properties": {
          "scope": {
            "anyOf": [
              { "required": ["css"] },
              { "required": ["xpath"] }
            ]
          }
        }
      }
    }
  ]
}

