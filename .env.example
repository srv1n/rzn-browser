# RZN Browser Automation Environment Configuration
# Copy this file to .env and fill in your API keys

# ==============================================================================
# LLM Configuration (Pick a provider and set keys)
# ==============================================================================

# Option 1: Google Gemini (Recommended - 50% cheaper)
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL_PLANNING=gemini-2.0-flash    # Options: gemini-2.0-flash, gemini-1.5-pro
GEMINI_MODEL_EXECUTION=gemini-2.0-flash   # gemini-2.0-flash is most cost-effective
GEMINI_TEMPERATURE=1.0                    # Temperature for Gemini (0.0-2.0, default: 1.0)

# Option 2: OpenAI (Responses API supported)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL_PLANNING=gpt-4o-mini     # Default used when unset; override with any supported OpenAI model
OPENAI_MODEL_EXECUTION=gpt-4o-mini    # Optional execution model override
OPENAI_TEMPERATURE=1.0                # Temperature for OpenAI (reasoning models only support 1.0)
OPENAI_MAX_TOKENS=2048                # Hard cap per completion (bumped to avoid truncation)

# Option 3: Anthropic (Claude)
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL_PLANNING=claude-3-5-sonnet-latest
ANTHROPIC_MODEL_EXECUTION=claude-3-5-sonnet-latest
ANTHROPIC_TEMPERATURE=1.0

# Option 4: Groq (OpenAI-compatible Chat Completions)
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL_PLANNING=llama-3.1-70b-versatile
GROQ_MODEL_EXECUTION=llama-3.1-70b-versatile
GROQ_TEMPERATURE=1.0

# Select your LLM provider (defaults to openai if not set)
LLM_PROVIDER=openai                     # Options: openai, gemini, anthropic/claude, groq, dummy, claude-cli, gemini-cli, codex-cli

# ==============================================================================
# How it works:
# 1. Set LLM_PROVIDER to your preferred provider
# 2. Provide the corresponding API key and model settings above
# 3. The system will use the provider specified in LLM_PROVIDER
# ==============================================================================

# ==============================================================================
# Transport Configuration
# ==============================================================================
RZN_TRANSPORT=native                      # Options: native (default), pipe (legacy), tcp
# RZN_TCP_PORT=30123                      # Only needed if using tcp transport

# ==============================================================================
# Logging Configuration
# ==============================================================================
RUST_LOG=info                             # Options: error, warn, info, debug, trace

# ==============================================================================
# Feature Flags
# ==============================================================================
# RZN_ENABLE_TELEMETRY=true               # Enable telemetry collection (future)
# RZN_TIMEOUT_MS=15000                    # Global timeout for operations (future)
RZN_ALLOWED_HOSTS=google.com             # Comma-separated allowlist for navigation (planner-enforced)
# Tip: for HN-style tasks, include news.ycombinator.com in the allowlist if you rely on LLM-driven navigate actions
# RZN_ALLOWED_HOSTS=google.com,news.ycombinator.com

# ==============================================================================
# Cost Comparison (2025 pricing per 1M tokens)
# ==============================================================================
# gemini-2.0-flash: $0.075 input / $0.30 output
# Gemini-1.5-pro:   $1.25 input / $5.00 output
# GPT-4o-mini:      $0.15 input / $0.60 output  
# GPT-4o:           $2.50 input / $10.00 output
# ==============================================================================
