{
  "schema_version": "rzn.workflow_manifest",
  "id": "google/flights",
  "name": "Google Flights Lookup",
  "version": "1.1.0",
  "system": "google",
  "capability": "google.flights",
  "summary": "Look up flights via Google Search and return the visible Flights widget text. Best-effort.",
  "description": "Search for flights from origin to destination via Google Search and extract the visible Flights widget text (best-effort).",
  "params": {
    "properties": {
      "destination": {
        "kind": "string",
        "required": true,
        "description": "Arrival city or airport code."
      },
      "origin": {
        "kind": "string",
        "required": true,
        "description": "Departure city or airport code. City names work; IATA codes (JFK, LHR) are most reliable."
      }
    },
    "additional_params": false
  },
  "side_effects": [
    {
      "class": "browser_state",
      "idempotency": "safe_retry",
      "confirmation_required": false,
      "scopes": [
        "google.com"
      ]
    },
    {
      "class": "read_only",
      "idempotency": "safe_retry",
      "confirmation_required": false,
      "scopes": [
        "google.com"
      ]
    }
  ],
  "runtime": {
    "actor": "supervisor",
    "requires_cdp": false,
    "requires_existing_session": false,
    "timeout_ms": 90000
  },
  "steps": [
    {
      "id": "s1",
      "action": {
        "kind": "navigate_to_url",
        "inputs": {
          "url": "https://www.google.com/search?q=flights%20from%20{origin}%20to%20{destination}"
        },
        "side_effects": [
          "browser_state"
        ]
      },
      "name": "Navigate to Google Search flights query"
    },
    {
      "id": "s2",
      "action": {
        "kind": "wait_for_element",
        "inputs": {},
        "side_effects": [
          "read_only"
        ],
        "target": {
          "selector": "#search, #rso"
        }
      },
      "name": "Wait for results panel",
      "timeout_ms": 20000
    },
    {
      "id": "s3",
      "action": {
        "kind": "dismiss_popups",
        "inputs": {},
        "side_effects": [
          "browser_state"
        ]
      },
      "name": "Dismiss common popups"
    },
    {
      "id": "s4",
      "action": {
        "kind": "extract_structured_data",
        "inputs": {
          "extraction_type": "flights_text",
          "item_selector": "body",
          "fields": [
            {
              "name": "search_text",
              "selector": "#search"
            }
          ]
        },
        "side_effects": [
          "read_only"
        ]
      },
      "name": "Extract visible search panel text"
    }
  ],
  "result": {
    "artifact_policy": {
      "prefer_downloads": false
    },
    "include_debug": false,
    "output_schema": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "search_text": {
            "type": "string"
          }
        }
      }
    },
    "output_selector": {
      "step_id": "s4",
      "path": "$"
    }
  },
  "help": {
    "summary": "Look up flights via Google Search and return the visible Flights widget text. Best-effort.",
    "parameters": {
      "destination": "Arrival city or airport code.",
      "origin": "Departure city or airport code. City names work; IATA codes (JFK, LHR) are most reliable."
    },
    "examples": [
      {
        "command": "rzn-browser run google flights --param origin=\"NYC\" --param destination=\"LON\"",
        "description": "NYC \u2192 London flights."
      },
      {
        "command": "rzn-browser run google flights --param origin=\"SFO\" --param destination=\"NRT\"",
        "description": "SFO \u2192 Tokyo Narita."
      }
    ],
    "returns": [
      "Object with one field, search_text \u2014 the inner text of the #search panel, including the Flights widget. Parsing into structured price/date/airline rows is left to the caller because Google rotates that DOM frequently."
    ],
    "notes": [
      "This workflow does not pick dates or filter cabins \u2014 it returns whatever the default widget shows.",
      "For deeper flight queries (dates, cabin class), build on top of this output or open google/travel/flights directly via the orchestrator."
    ]
  },
  "metadata": {
    "migrated_from": "google/google-flights.json",
    "legacy_system_id": "google"
  }
}
