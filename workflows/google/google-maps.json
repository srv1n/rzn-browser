{
  "schema_version": "rzn.workflow_manifest",
  "id": "google/maps",
  "name": "Google Maps Places Search",
  "version": "2.1.0",
  "system": "google",
  "capability": "google.maps",
  "summary": "Search Google Maps for places and return the top 5 cards plus a map screenshot.",
  "description": "Search Google Maps for places matching a query and extract the top result cards plus a viewport screenshot of the map.",
  "params": {
    "properties": {
      "query": {
        "kind": "string",
        "required": true,
        "description": "Place search query, free text. Aliases search_query and q work too."
      }
    },
    "additional_params": false
  },
  "side_effects": [
    {
      "class": "browser_state",
      "idempotency": "safe_retry",
      "confirmation_required": false,
      "scopes": [
        "google.com"
      ]
    },
    {
      "class": "read_only",
      "idempotency": "safe_retry",
      "confirmation_required": false,
      "scopes": [
        "google.com"
      ]
    }
  ],
  "runtime": {
    "actor": "supervisor",
    "requires_cdp": false,
    "requires_existing_session": false,
    "timeout_ms": 90000
  },
  "steps": [
    {
      "id": "s1",
      "action": {
        "kind": "navigate_to_url",
        "inputs": {
          "url": "https://www.google.com/maps/search/?api=1&query={query}&hl=en",
          "wait": "domcontentloaded"
        },
        "side_effects": [
          "browser_state"
        ]
      },
      "name": "Navigate to Google Maps search",
      "timeout_ms": 30000
    },
    {
      "id": "s2",
      "action": {
        "kind": "dismiss_popups",
        "inputs": {},
        "side_effects": [
          "browser_state"
        ]
      },
      "name": "Dismiss common popups"
    },
    {
      "id": "s3",
      "action": {
        "kind": "wait_for_element",
        "inputs": {},
        "side_effects": [
          "read_only"
        ],
        "target": {
          "selector": "div.Nv2PK, a.hfpxzc, [role='main']"
        }
      },
      "name": "Wait for place result cards",
      "timeout_ms": 20000
    },
    {
      "id": "s4",
      "action": {
        "kind": "wait_for_timeout",
        "inputs": {},
        "side_effects": [
          "read_only"
        ]
      },
      "name": "Settle: let map pins render",
      "timeout_ms": 2000
    },
    {
      "id": "s5",
      "action": {
        "kind": "extract_structured_data",
        "inputs": {
          "extraction_type": "places",
          "item_selector": "div.Nv2PK",
          "limit": 5,
          "fields": [
            {
              "name": "name",
              "selector": ".qBF1Pd, .fontHeadlineSmall, [role='heading']"
            },
            {
              "name": "rating",
              "selector": ".MW4etd, .yi40Hd"
            },
            {
              "name": "reviews",
              "selector": ".UY7F9, span[aria-label*='review']",
              "post_processing": [
                "collapse_whitespace",
                "regex:([\\d,]+)"
              ]
            },
            {
              "name": "price_range",
              "selector": ".W4Efsd .AJB7ye > span:nth-child(3) > span:nth-child(2)",
              "post_processing": [
                "collapse_whitespace"
              ]
            },
            {
              "name": "category",
              "selector": ".W4Efsd .W4Efsd > span:first-child span",
              "post_processing": [
                "collapse_whitespace"
              ]
            },
            {
              "name": "address",
              "selector": ".W4Efsd .W4Efsd > span:last-child span:last-child",
              "post_processing": [
                "collapse_whitespace"
              ]
            },
            {
              "name": "description",
              "selector": "div.W4Efsd > div.W4Efsd:nth-child(2):not(:last-child)",
              "post_processing": [
                "collapse_whitespace"
              ]
            },
            {
              "name": "status",
              "selector": "div.W4Efsd > div.W4Efsd:last-child",
              "post_processing": [
                "collapse_whitespace"
              ]
            },
            {
              "name": "url",
              "selector": "a.hfpxzc, a[href*='/maps/place'], a[href*='google.com/maps/place']",
              "attribute": "href"
            }
          ]
        },
        "side_effects": [
          "read_only"
        ]
      },
      "name": "Extract place cards (top 5)"
    },
    {
      "id": "s6",
      "action": {
        "kind": "take_screenshot",
        "inputs": {
          "format": "png",
          "full_page": false
        },
        "side_effects": [
          "read_only"
        ]
      },
      "name": "Capture viewport map screenshot"
    }
  ],
  "result": {
    "artifact_policy": {
      "prefer_downloads": false
    },
    "include_debug": false,
    "output_schema": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "rating": {
            "type": "string"
          },
          "reviews": {
            "type": "string"
          },
          "price_range": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        }
      }
    },
    "output_selector": {
      "step_id": "s5",
      "path": "$"
    }
  },
  "help": {
    "summary": "Search Google Maps for places and return the top 5 cards plus a map screenshot.",
    "parameters": {
      "query": "Place search query, free text. Aliases search_query and q work too."
    },
    "examples": [
      {
        "command": "rzn-browser run google maps --param query=\"pizza near Central Park\"",
        "description": "Find pizza spots near Central Park."
      },
      {
        "command": "rzn-browser run google maps --param search_query=\"coffee shops in Berlin Mitte\"",
        "description": "Use the search_query alias with a neighborhood scope."
      }
    ],
    "returns": [
      "Primary output (step s5): array of up to 5 places { name, rating, reviews, price_range, category, address, description, status, url }. Step s6 additionally captures a viewport map screenshot (written under test-results/workflow-artifacts/google-maps/). For directions between two places, use google/maps-directions instead."
    ],
    "notes": [
      "Set hl=en in the URL \u2014 without an explicit locale, results vary with Maps' geo guess.",
      "rating/reviews can be empty for places without enough reviews.",
      "url points at the Maps place page (google.com/maps/place/...), not the place's own website."
    ]
  },
  "metadata": {
    "migrated_from": "google/google-maps.json",
    "legacy_system_id": "google"
  }
}
