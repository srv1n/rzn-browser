{
  "system_id": "google",
  "id": "google_finance_v2",
  "name": "Google Finance Quote Lookup",
  "description": "Open a Google Finance quote page and extract structured fields: price, change, name, exchange, currency, plus key stats and an optional viewport screenshot.",
  "domain": "google.com",
  "version": "2.1.0",
  "last_updated": "2026-04-24T00:00:00Z",
  "browser_automation": {
    "description": "Loads google.com/finance/quote/<TICKER:EXCHANGE>. Extraction is regex-driven against best-effort selectors because Finance is heavily client-rendered.",
    "sequences": [
      {
        "name": "google_finance_quote_extract",
        "description": "Open a quote page, extract structured quote fields plus key stats rows, and capture a screenshot.",
        "required_variables": [
          {
            "name": "query",
            "description": "Ticker with exchange suffix, in TICKER:EXCHANGE format (e.g. AAPL:NASDAQ, GOOGL:NASDAQ, BRK.A:NYSE)."
          }
        ],
        "steps": [
          {
            "id": "s1",
            "name": "Navigate to Google Finance quote page",
            "type": "navigate_to_url",
            "url": "https://www.google.com/finance/quote/{query}",
            "wait": "domcontentloaded",
            "timeout_ms": 30000
          },
          {
            "id": "s2",
            "name": "Dismiss common popups",
            "type": "dismiss_popups"
          },
          {
            "id": "s3",
            "name": "Settle: let client-rendered quote content load",
            "type": "wait_for_timeout",
            "timeout_ms": 2500
          },
          {
            "id": "s4",
            "name": "Extract quote fields",
            "type": "extract_structured_data",
            "extraction_type": "quote",
            "item_selector": "html",
            "limit": 1,
            "fields": [
              {
                "name": "ticker",
                "selector": "link[rel='canonical']",
                "attribute": "href",
                "post_processing": ["collapse_whitespace", "regex:quote/([^/?#]+)"]
              },
              {
                "name": "symbol",
                "selector": "link[rel='canonical']",
                "attribute": "href",
                "post_processing": ["regex:quote/([A-Z0-9\\\\-\\\\.]+)"]
              },
              {
                "name": "exchange",
                "selector": "link[rel='canonical']",
                "attribute": "href",
                "post_processing": ["regex:quote/[A-Z0-9\\\\-\\\\.]+:([A-Z0-9\\\\-\\\\.]+)"]
              },
              {
                "name": "name",
                "selector": "div.IHz7Sd div.gO24Ff, .zzDege",
                "post_processing": ["collapse_whitespace"]
              },
              {
                "name": "currency",
                "selector": "div.IHz7Sd div.jZZ2de",
                "post_processing": ["collapse_whitespace", "regex:([A-Z]{3})[^A-Z]*$"]
              },
              {
                "name": "currency_symbol",
                "selector": "div.IHz7Sd div.N6SYTe span[jsname='Pdsbrc'] span",
                "post_processing": ["regex:([\\\\$€£¥₹])"]
              },
              {
                "name": "price",
                "selector": "div.IHz7Sd div.N6SYTe span[jsname='Pdsbrc'] span, .fxKbKc, .kf1m0",
                "post_processing": ["collapse_whitespace", "regex:([0-9][0-9,.]*)"]
              },
              {
                "name": "display_price",
                "selector": "div.IHz7Sd div.N6SYTe span[jsname='Pdsbrc'] span, .fxKbKc, .kf1m0",
                "post_processing": ["collapse_whitespace", "regex:([\\\\$€£¥₹]?\\\\s*[0-9][0-9,.]*)"]
              },
              {
                "name": "change_pct",
                "selector": "div.IHz7Sd span[jsname='vY9t3b'] span",
                "post_processing": ["collapse_whitespace", "regex:([-+]?\\\\d[\\\\d,.]*%)"]
              },
              {
                "name": "change_abs",
                "selector": "div.IHz7Sd span[jsname='xnruHf'] span",
                "post_processing": ["collapse_whitespace", "regex:([-+]?\\\\d[\\\\d,.]*)"]
              },
              {
                "name": "market_time",
                "selector": "div.IHz7Sd div.jZZ2de",
                "post_processing": ["collapse_whitespace"]
              },
              {
                "name": "market_state",
                "selector": "div.IHz7Sd div.jZZ2de",
                "post_processing": ["collapse_whitespace", "regex:^(Closed|Open)"]
              },
              {
                "name": "about",
                "selector": ".RaUwRb span, .bLLb2d, .Yfwt5",
                "post_processing": ["collapse_whitespace"]
              }
            ]
          },
          {
            "id": "s4b",
            "name": "Extract key stats rows",
            "type": "extract_structured_data",
            "extraction_type": "stats",
            "item_selector": "div.KxsRFb, .gyFHrc .P6K39c, .eYanAe .P6K39c, table.slpEwd tr",
            "limit": 50,
            "fields": [
              { "name": "label", "selector": ".SwQK7, .mfs7Fc, td:first-child, th:first-child", "post_processing": ["collapse_whitespace"] },
              { "name": "value", "selector": ".dO6ijd, .QXDnM, td:last-child, th:last-child", "post_processing": ["collapse_whitespace"] }
            ]
          },
          {
            "id": "s5",
            "name": "Capture viewport screenshot",
            "type": "take_screenshot",
            "format": "png",
            "full_page": false
          }
        ]
      }
    ]
  },
  "help": {
    "summary": "Look up a stock/ETF/index on Google Finance and return structured quote + key stats + screenshot.",
    "parameters": [
      {
        "name": "query",
        "required": true,
        "shape": "ticker:exchange",
        "description": "Ticker symbol with exchange suffix. Examples: AAPL:NASDAQ, MSFT:NASDAQ, BRK.A:NYSE, .DJI:INDEXDJX, BTC-USD. The colon-suffix is required by Finance's URL routing.",
        "example": "AAPL:NASDAQ"
      }
    ],
    "examples": [
      {
        "command": "rzn-browser run google finance --param query=\"AAPL:NASDAQ\"",
        "description": "Apple quote."
      },
      {
        "command": "rzn-browser run google finance --param query=\".DJI:INDEXDJX\"",
        "description": "Dow Jones index."
      }
    ],
    "returns": "Object with two arrays: a 1-row 'quote' object (ticker, symbol, exchange, name, currency, currency_symbol, price, display_price, change_pct, change_abs, market_time, market_state, about) and a 'stats' array of {label, value} rows. Screenshot is written to test-results/workflow-artifacts/google-finance/.",
    "notes": [
      "Selector classes are minified Google class names — they rotate occasionally, which is why most fields use multiple selector fallbacks plus regex post-processing.",
      "If a field comes back empty, verify against the live page; the regex captures may need a refresh.",
      "Only a single ticker per run; for batch lookups, call repeatedly."
    ]
  }
}
