{
  "schema_version": "rzn.workflow_manifest",
  "id": "x/send_dm",
  "name": "X: Send DM",
  "version": "1.1.0",
  "system": "x",
  "capability": "x.send.dm",
  "summary": "Open a new DM with a handle and send a message after human approval.",
  "description": "Open a recipient profile in a fresh tab, launch the DM composer, draft a first message, pause for human approval, then send. Use when you need to open a NEW DM conversation with a user by handle. Do not use when you already have an open thread URL (use `x_reply_dm_thread`).",
  "params": {
    "properties": {
      "message_text": {
        "kind": "string",
        "required": true,
        "description": "Message body to send."
      },
      "recipient_handle": {
        "kind": "string",
        "required": true,
        "description": "Recipient X handle without the leading @."
      }
    },
    "additional_params": false
  },
  "side_effects": [
    {
      "class": "auth",
      "idempotency": "safe_retry",
      "confirmation_required": false,
      "scopes": [
        "x.com"
      ]
    },
    {
      "class": "browser_state",
      "idempotency": "safe_retry",
      "confirmation_required": false,
      "scopes": [
        "x.com"
      ]
    },
    {
      "class": "read_only",
      "idempotency": "safe_retry",
      "confirmation_required": false,
      "scopes": [
        "x.com"
      ]
    },
    {
      "class": "external_write",
      "idempotency": "never_retry",
      "confirmation_required": true,
      "scopes": [
        "x.com"
      ]
    }
  ],
  "runtime": {
    "actor": "supervisor",
    "requires_cdp": false,
    "requires_existing_session": false,
    "timeout_ms": 90000
  },
  "steps": [
    {
      "id": "s0",
      "action": {
        "kind": "navigate_to_url",
        "inputs": {
          "url": "https://x.com/{recipient_handle}"
        },
        "side_effects": [
          "browser_state"
        ]
      },
      "name": "Open the recipient profile in a fresh tab",
      "timeout_ms": 60000
    },
    {
      "id": "s1",
      "action": {
        "kind": "wait_for_timeout",
        "inputs": {},
        "side_effects": [
          "read_only"
        ]
      },
      "name": "Allow the profile page to settle",
      "timeout_ms": 2000
    },
    {
      "id": "s2",
      "action": {
        "kind": "dismiss_popups",
        "inputs": {},
        "side_effects": [
          "browser_state"
        ]
      },
      "name": "Dismiss popups if present"
    },
    {
      "id": "s3",
      "action": {
        "kind": "wait_for_element",
        "inputs": {},
        "side_effects": [
          "read_only"
        ],
        "target": {
          "selector": "div[role='button'][data-testid='sendDMFromProfile'], button[data-testid='sendDMFromProfile'], a[href*='/messages/compose'], button[aria-label*='Message' i], a[aria-label*='Message' i]"
        }
      },
      "name": "Wait for the profile DM button",
      "timeout_ms": 20000
    },
    {
      "id": "s4",
      "action": {
        "kind": "click_element",
        "inputs": {},
        "side_effects": [
          "browser_state"
        ],
        "target": {
          "selector": "div[role='button'][data-testid='sendDMFromProfile'], button[data-testid='sendDMFromProfile'], a[href*='/messages/compose'], button[aria-label*='Message' i], a[aria-label*='Message' i]"
        }
      },
      "name": "Open the DM composer",
      "timeout_ms": 15000
    },
    {
      "id": "s5",
      "action": {
        "kind": "wait_for_element",
        "inputs": {},
        "side_effects": [
          "read_only"
        ],
        "target": {
          "selector": "div[data-testid='dmComposerTextInput'], div[role='textbox'][data-testid='dmComposerTextInput'], div[role='textbox'][contenteditable='true'], button[data-testid='pin-onboarding-setup-now']"
        }
      },
      "name": "Wait for the DM composer or X Chat onboarding gate",
      "timeout_ms": 20000
    },
    {
      "id": "s6",
      "action": {
        "kind": "request_user_intervention",
        "inputs": {
          "message": "If X Chat asks you to create a passcode, finish that setup now. Otherwise click Continue immediately.",
          "instructions": "After the passcode gate is cleared, the workflow will wait for the DM composer and continue typing.",
          "approval_mode": "ask_user",
          "continue_on_timeout": false
        },
        "side_effects": [
          "browser_state"
        ]
      },
      "name": "Pause if X Chat requires passcode setup",
      "timeout_ms": 2147483647
    },
    {
      "id": "s7",
      "action": {
        "kind": "wait_for_element",
        "inputs": {},
        "side_effects": [
          "read_only"
        ],
        "target": {
          "selector": "div[data-testid='dmComposerTextInput'], div[role='textbox'][data-testid='dmComposerTextInput'], div[role='textbox'][contenteditable='true']"
        }
      },
      "name": "Wait for the DM composer after onboarding is cleared",
      "timeout_ms": 20000
    },
    {
      "id": "s8",
      "action": {
        "kind": "click_element",
        "inputs": {},
        "side_effects": [
          "browser_state"
        ],
        "target": {
          "selector": "div[data-testid='dmComposerTextInput'], div[role='textbox'][data-testid='dmComposerTextInput'], div[role='textbox'][contenteditable='true']"
        }
      },
      "name": "Activate the DM composer",
      "timeout_ms": 10000
    },
    {
      "id": "s9",
      "action": {
        "kind": "wait_for_timeout",
        "inputs": {},
        "side_effects": [
          "read_only"
        ]
      },
      "name": "Allow the DM caret to settle",
      "timeout_ms": 350
    },
    {
      "id": "s10",
      "action": {
        "kind": "type_text",
        "inputs": {
          "use_native_input": false,
          "delay_ms": 35,
          "typing_speed": "medium"
        },
        "side_effects": [
          "browser_state"
        ],
        "target": {
          "selector": "div[data-testid='dmComposerTextInput'], div[role='textbox'][data-testid='dmComposerTextInput'], div[role='textbox'][contenteditable='true']",
          "text": "{message_text}"
        }
      },
      "name": "Type the DM message",
      "timeout_ms": 120000
    },
    {
      "id": "s11",
      "action": {
        "kind": "assert_selector_state",
        "inputs": {
          "condition": "enabled"
        },
        "side_effects": [
          "read_only"
        ],
        "target": {
          "selector": "button[data-testid='dmComposerSendButton'], div[role='button'][data-testid='dmComposerSendButton'], button[aria-label*='Send' i]"
        }
      },
      "name": "Confirm the DM send control is enabled",
      "timeout_ms": 5000
    },
    {
      "id": "s12",
      "action": {
        "kind": "request_user_intervention",
        "inputs": {
          "message": "DM draft is ready. Click Continue only if you want to send it.",
          "instructions": "If you do not want to send this message, stop the workflow instead of waiting for the timeout.",
          "approval_mode": "ask_user",
          "continue_on_timeout": false
        },
        "side_effects": [
          "browser_state"
        ]
      },
      "name": "Pause for review before sending the DM",
      "timeout_ms": 2147483647
    },
    {
      "id": "s13",
      "action": {
        "kind": "click_element",
        "inputs": {},
        "side_effects": [
          "browser_state",
          "external_write"
        ],
        "target": {
          "selector": "button[data-testid='dmComposerSendButton'], div[role='button'][data-testid='dmComposerSendButton'], button[aria-label*='Send' i]"
        }
      },
      "name": "Click the DM send control",
      "timeout_ms": 10000
    },
    {
      "id": "s14",
      "action": {
        "kind": "wait_for_timeout",
        "inputs": {},
        "side_effects": [
          "read_only"
        ]
      },
      "name": "Allow the DM send to settle",
      "timeout_ms": 900
    },
    {
      "id": "s15",
      "action": {
        "kind": "execute_javascript",
        "inputs": {
          "world": "main",
          "script": "const normalize = (value) => (value || '').replace(/\\u00a0/g, ' ').replace(/\\s+/g, ' ').trim(); const composer = document.querySelector(\"div[data-testid='dmComposerTextInput'], div[role='textbox'][data-testid='dmComposerTextInput'], div[role='textbox'][contenteditable='true']\"); return { url: location.href, composer_text: composer ? normalize(composer.textContent || '') : null, send_button_present: !!document.querySelector(\"button[data-testid='dmComposerSendButton'], div[role='button'][data-testid='dmComposerSendButton'], button[aria-label*='Send' i]\"), pin_onboarding_present: !!document.querySelector(\"button[data-testid='pin-onboarding-setup-now']\") };"
        },
        "side_effects": [
          "read_only"
        ]
      },
      "name": "Read the final DM composer state",
      "timeout_ms": 10000
    }
  ],
  "result": {
    "artifact_policy": {
      "prefer_downloads": false
    },
    "include_debug": false,
    "output_schema": {
      "type": "object",
      "properties": {
        "url": { "type": "string" },
        "composer_text": { "type": ["string", "null"] },
        "send_button_present": { "type": "boolean" },
        "pin_onboarding_present": { "type": "boolean" }
      }
    },
    "output_selector": {
      "step_id": "s15",
      "path": "$"
    }
  },
  "help": {
    "summary": "Open a new DM with a handle and send a message after human approval.",
    "parameters": {
      "message_text": "Message body to send.",
      "recipient_handle": "Recipient X handle without the leading @."
    },
    "examples": [
      {
        "command": "rzn-browser run x send-dm --param recipient_handle=\"jack\" --param message_text=\"Today's a great day\"",
        "description": "Send a first DM to a handle after confirming at the review gate."
      }
    ],
    "returns": [
      "{ url, composer_text, send_button_present, pin_onboarding_present } post-send."
    ],
    "notes": [
      "Mutating. Two gates: one for passcode setup (if shown), one for send approval.",
      "Opens a fresh tab; parallel DM sends to different handles are safe.",
      "Recipient must accept DMs from the authenticated user for the Message button to exist."
    ]
  },
  "metadata": {
    "migrated_from": "x/x_send_dm.json",
    "legacy_system_id": "x"
  }
}
