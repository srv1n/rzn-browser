{
  "schema_version": "rzn.workflow_manifest",
  "id": "sciencedirect/search",
  "name": "ScienceDirect Search Workflow",
  "version": "2.0.0",
  "system": "sciencedirect",
  "capability": "sciencedirect.search",
  "summary": "Search ScienceDirect and return the first page of result metadata (title, authors, journal, date, URL, DOI, article type, open-access status).",
  "description": "Search ScienceDirect and extract paper metadata from the first results page.",
  "params": {
    "properties": {
      "search_query": {
        "kind": "string",
        "required": true,
        "description": "Free-text query for academic papers. Supports standard ScienceDirect search syntax."
      }
    },
    "additional_params": false
  },
  "side_effects": [
    {
      "class": "browser_state",
      "idempotency": "safe_retry",
      "confirmation_required": false,
      "scopes": [
        "sciencedirect.com"
      ]
    },
    {
      "class": "read_only",
      "idempotency": "safe_retry",
      "confirmation_required": false,
      "scopes": [
        "sciencedirect.com"
      ]
    }
  ],
  "runtime": {
    "actor": "supervisor",
    "requires_cdp": false,
    "requires_existing_session": false,
    "timeout_ms": 90000
  },
  "steps": [
    {
      "id": "s1",
      "action": {
        "kind": "navigate_to_url",
        "inputs": {
          "url": "https://www.sciencedirect.com/search?qs={search_query}"
        },
        "side_effects": [
          "browser_state"
        ]
      },
      "name": "Navigate to search results"
    },
    {
      "id": "s2",
      "action": {
        "kind": "wait_for_element",
        "inputs": {},
        "side_effects": [
          "read_only"
        ],
        "target": {
          "selector": "#srp-results-list"
        }
      },
      "name": "Wait for results container",
      "timeout_ms": 15000
    },
    {
      "id": "s3",
      "action": {
        "kind": "wait_for_timeout",
        "inputs": {},
        "side_effects": [
          "read_only"
        ]
      },
      "name": "Settle dynamic content",
      "timeout_ms": 1500
    },
    {
      "id": "s4",
      "action": {
        "kind": "extract_structured_data",
        "inputs": {
          "item_selector": "li.ResultItem",
          "fields": [
            {
              "name": "title",
              "selector": "h2 a"
            },
            {
              "name": "url",
              "selector": "h2 a",
              "attribute": "href"
            },
            {
              "name": "authors",
              "selector": ".Authors"
            },
            {
              "name": "journal",
              "selector": ".srctitle-date-fields a"
            },
            {
              "name": "date",
              "selector": ".srctitle-date-fields > span:last-child"
            },
            {
              "name": "article_type",
              "selector": ".article-type"
            },
            {
              "name": "access_type",
              "selector": ".access-label"
            },
            {
              "name": "doi",
              "selector": "*",
              "attribute": "data-doi"
            }
          ]
        },
        "side_effects": [
          "read_only"
        ]
      },
      "name": "Extract result metadata"
    }
  ],
  "result": {
    "artifact_policy": {
      "prefer_downloads": false
    },
    "include_debug": false,
    "output_schema": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "authors": {
            "type": "string"
          },
          "journal": {
            "type": "string"
          },
          "date": {
            "type": "string"
          },
          "article_type": {
            "type": "string"
          },
          "access_type": {
            "type": "string"
          },
          "doi": {
            "type": "string"
          }
        }
      }
    },
    "output_selector": {
      "step_id": "s4",
      "path": "$"
    }
  },
  "help": {
    "summary": "Search ScienceDirect and return the first page of result metadata (title, authors, journal, date, URL, DOI, article type, open-access status).",
    "parameters": {
      "search_query": "Free-text query for academic papers. Supports standard ScienceDirect search syntax."
    },
    "examples": [
      {
        "command": "rzn-browser run sciencedirect search --param search_query=\"machine learning\"",
        "description": "Search for papers about machine learning."
      },
      {
        "command": "rzn-browser run sciencedirect search --param search_query=\"graphene supercapacitor 2024\"",
        "description": "Narrower topical + year search."
      }
    ],
    "returns": [
      "Array of result items (one SERP page, up to ~25). Each item has: title, url (relative /science/article/pii/... path), authors, journal, date, article_type, access_type (\"Open access\" when present; absent on paywalled), doi."
    ],
    "notes": [
      "Only one results page is extracted. Paginate by issuing narrower queries rather than walking pages.",
      "Abstracts are not rendered on the SRP; use sciencedirect paper-access for the full abstract.",
      "doi is read from the li[data-doi] attribute, not rendered text.",
      "The url field is a relative path; prefix with https://www.sciencedirect.com to resolve."
    ]
  },
  "metadata": {
    "migrated_from": "sciencedirect/sciencedirect-search.json",
    "legacy_system_id": "sciencedirect"
  }
}
