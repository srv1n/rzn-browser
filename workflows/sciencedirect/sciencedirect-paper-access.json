{
  "schema_version": "rzn.workflow_manifest",
  "id": "sciencedirect/paper_access",
  "name": "ScienceDirect Paper Access Workflow",
  "version": "2.0.0",
  "system": "sciencedirect",
  "capability": "sciencedirect.paper.access",
  "summary": "Open a ScienceDirect article page and return title, journal, citation, DOI, abstract, PDF link, and author list.",
  "description": "Fetch a ScienceDirect paper's metadata, abstract, and PDF link.",
  "params": {
    "properties": {
      "paper_url": {
        "kind": "string",
        "required": true,
        "description": "Absolute URL to a ScienceDirect article (.../science/article/pii/<PII>). Pre-resolve DOIs to a ScienceDirect URL before calling."
      }
    },
    "additional_params": false
  },
  "side_effects": [
    {
      "class": "browser_state",
      "idempotency": "safe_retry",
      "confirmation_required": false,
      "scopes": [
        "sciencedirect.com"
      ]
    },
    {
      "class": "read_only",
      "idempotency": "safe_retry",
      "confirmation_required": false,
      "scopes": [
        "sciencedirect.com"
      ]
    }
  ],
  "runtime": {
    "actor": "supervisor",
    "requires_cdp": false,
    "requires_existing_session": false,
    "timeout_ms": 90000
  },
  "steps": [
    {
      "id": "s1",
      "action": {
        "kind": "navigate_to_url",
        "inputs": {
          "url": "{paper_url}"
        },
        "side_effects": [
          "browser_state"
        ]
      },
      "name": "Navigate to paper URL"
    },
    {
      "id": "s2",
      "action": {
        "kind": "wait_for_element",
        "inputs": {},
        "side_effects": [
          "read_only"
        ],
        "target": {
          "selector": "span.title-text"
        }
      },
      "name": "Wait for article title",
      "timeout_ms": 15000
    },
    {
      "id": "s3",
      "action": {
        "kind": "wait_for_timeout",
        "inputs": {},
        "side_effects": [
          "read_only"
        ]
      },
      "name": "Settle dynamic content",
      "timeout_ms": 1500
    },
    {
      "id": "s4",
      "action": {
        "kind": "extract_structured_data",
        "inputs": {
          "item_selector": "body",
          "limit": 1,
          "fields": [
            {
              "name": "title",
              "selector": "span.title-text"
            },
            {
              "name": "journal",
              "selector": ".publication-title-link"
            },
            {
              "name": "citation",
              "selector": ".publication-brand .text-xs"
            },
            {
              "name": "doi",
              "selector": "a.doi",
              "attribute": "href"
            },
            {
              "name": "abstract",
              "selector": "div.abstract.author"
            },
            {
              "name": "pdf_url",
              "selector": "a.accessbar-utility-link",
              "attribute": "href"
            }
          ]
        },
        "side_effects": [
          "read_only"
        ]
      },
      "name": "Extract paper metadata"
    },
    {
      "id": "s5",
      "action": {
        "kind": "extract_structured_data",
        "inputs": {
          "item_selector": ".author-group a",
          "fields": [
            {
              "name": "name",
              "selector": "*"
            }
          ]
        },
        "side_effects": [
          "read_only"
        ]
      },
      "name": "Extract authors"
    }
  ],
  "result": {
    "artifact_policy": {
      "prefer_downloads": false
    },
    "include_debug": false,
    "output_schema": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "journal": {
            "type": "string"
          },
          "citation": {
            "type": "string"
          },
          "doi": {
            "type": "string"
          },
          "abstract": {
            "type": "string"
          },
          "pdf_url": {
            "type": "string"
          }
        }
      }
    },
    "output_selector": {
      "step_id": "s4",
      "path": "$"
    }
  },
  "help": {
    "summary": "Open a ScienceDirect article page and return title, journal, citation, DOI, abstract, PDF link, and author list.",
    "parameters": {
      "paper_url": "Absolute URL to a ScienceDirect article (.../science/article/pii/<PII>). Pre-resolve DOIs to a ScienceDirect URL before calling."
    },
    "examples": [
      {
        "command": "rzn-browser run sciencedirect paper-access --param paper_url=\"https://www.sciencedirect.com/science/article/pii/S2666389920301896\"",
        "description": "Fetch full metadata for an open-access paper."
      }
    ],
    "returns": [
      "Primary output (array, one item): { title, journal, citation, doi, abstract, pdf_url }. citation example: 'Volume 1, Issue 9, 11 December 2020, 100141'. The author list (array of { name }) is produced by step s5 and surfaces as a step-level result, not the primary output."
    ],
    "notes": [
      "pdf_url points to the /pdfft entitlement endpoint; for paywalled articles this redirects to an access-required page rather than a PDF.",
      "citation bundles volume, issue, date, and page/article number \u2014 callers parse if individual fields are needed.",
      "abstract is pulled from div.abstract.author and may include a leading section title (e.g. 'Summary').",
      "Read-only: no login is performed by this workflow. If the active Chrome profile already carries institutional/entitlement cookies, ScienceDirect may surface gated content; that is a session-state effect, not an explicit auth step here."
    ]
  },
  "metadata": {
    "migrated_from": "sciencedirect/sciencedirect-paper-access.json",
    "legacy_system_id": "sciencedirect_paper"
  }
}
