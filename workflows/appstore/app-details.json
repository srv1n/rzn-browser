{
  "schema_version": "rzn.workflow_manifest",
  "id": "appstore/app_details",
  "name": "App Store: App Details",
  "version": "2.0.0",
  "system": "appstore",
  "capability": "appstore.app.details",
  "summary": "Open one App Store app page; return metadata, screenshots, and reviews.",
  "description": "Open one App Store app page and extract title, subtitle, category, description, version info, ratings summary, screenshot sources, and review rows. Accepts either a numeric `app_id` or a full `app_url`. Use `mode` to choose how deep to go on reviews. Read-only.",
  "params": {
    "properties": {
      "app_id": {
        "kind": "string",
        "required": false,
        "description": "Numeric App Store app id. Either this or app_url must be given."
      },
      "app_url": {
        "kind": "string",
        "required": false,
        "description": "Full App Store URL. Overrides app_id when both are set."
      },
      "country": {
        "kind": "string",
        "required": false,
        "default": "us",
        "description": "Two-letter storefront code. Used only when constructing the URL from app_id."
      },
      "mode": {
        "kind": "string",
        "required": false,
        "default": "with-reviews",
        "description": "with-reviews (default) = metadata + screenshots + on-page reviews; full = also opens /see-all=reviews for a deeper review batch.",
        "enum_values": [
          "with-reviews",
          "full"
        ]
      }
    },
    "additional_params": false
  },
  "side_effects": [
    {
      "class": "browser_state",
      "idempotency": "safe_retry",
      "confirmation_required": false,
      "scopes": [
        "apps.apple.com"
      ]
    },
    {
      "class": "read_only",
      "idempotency": "safe_retry",
      "confirmation_required": false,
      "scopes": [
        "apps.apple.com"
      ]
    }
  ],
  "runtime": {
    "actor": "supervisor",
    "requires_cdp": false,
    "requires_existing_session": false,
    "timeout_ms": 90000
  },
  "steps": [
    {
      "id": "s1",
      "action": {
        "kind": "open_new_tab",
        "inputs": {
          "url": "https://apps.apple.com/us/"
        },
        "side_effects": [
          "browser_state"
        ]
      },
      "name": "Open the App Store in a fresh tab"
    },
    {
      "id": "s1b",
      "action": {
        "kind": "execute_javascript",
        "inputs": {
          "world": "main",
          "script": "const cleanArg = (v) => { const t = String(v == null ? '' : v).trim(); return /^\\{[a-zA-Z0-9_]+\\}$/.test(t) ? '' : t; };\nconst app_url = cleanArg('{app_url}');\nconst app_id = cleanArg('{app_id}');\nconst country = (cleanArg('{country}') || 'us').toLowerCase();\nlet target;\nif (app_url) { target = app_url; } else if (app_id) { target = `https://apps.apple.com/${encodeURIComponent(country)}/app/id${encodeURIComponent(app_id)}`; } else { return { error: 'must provide app_id or app_url' }; }\nsetTimeout(() => window.location.assign(target), 0);\nreturn { redirected: true, target };",
          "return_value": true
        },
        "side_effects": [
          "browser_state"
        ]
      },
      "name": "Resolve target URL from app_id / app_url / country and redirect"
    },
    {
      "id": "s2",
      "action": {
        "kind": "wait_for_timeout",
        "inputs": {},
        "side_effects": [
          "read_only"
        ]
      },
      "name": "Wait for hydration",
      "timeout_ms": 4000
    },
    {
      "id": "s3",
      "action": {
        "kind": "wait_for_element",
        "inputs": {},
        "side_effects": [
          "read_only"
        ],
        "target": {
          "selector": "h1"
        }
      },
      "name": "Wait for app title",
      "timeout_ms": 20000
    },
    {
      "id": "s4",
      "action": {
        "kind": "wait_for_element",
        "inputs": {},
        "side_effects": [
          "read_only"
        ],
        "target": {
          "selector": "#product_media_phone_, [id^='product_media_']"
        }
      },
      "name": "Wait for screenshot media section",
      "timeout_ms": 15000
    },
    {
      "id": "s5",
      "action": {
        "kind": "wait_for_element",
        "inputs": {},
        "side_effects": [
          "read_only"
        ],
        "target": {
          "selector": "#productRatings, #allProductReviews"
        }
      },
      "name": "Wait for ratings/reviews section",
      "timeout_ms": 20000
    },
    {
      "id": "s6",
      "action": {
        "kind": "execute_javascript",
        "inputs": {
          "world": "main",
          "script": "(async () => { const sleep = (ms) => new Promise(r=>setTimeout(r,ms)); for (let i=0;i<4;i++) { window.scrollBy(0, 1500); await sleep(700); } window.scrollTo(0,0); return { scrolled: 4 }; })()",
          "return_value": true
        },
        "side_effects": [
          "browser_state"
        ]
      },
      "name": "Scroll the page to force lazy review content to mount"
    },
    {
      "id": "s7",
      "action": {
        "kind": "extract_structured_data",
        "inputs": {
          "item_selector": "main",
          "limit": 1,
          "fields": [
            {
              "name": "app_title",
              "selector": "h1",
              "post_processing": [
                "collapse_whitespace"
              ]
            },
            {
              "name": "subtitle",
              "selector": "h2.product-header__identity, h2",
              "post_processing": [
                "collapse_whitespace"
              ]
            },
            {
              "name": "price_or_get_label",
              "selector": "button.we-button, .app-header__list__item, li.inline-list__item",
              "post_processing": [
                "collapse_whitespace"
              ]
            },
            {
              "name": "category",
              "selector": "dd.information-list__item__definition a, .information-list__item__definition a",
              "post_processing": [
                "collapse_whitespace"
              ]
            },
            {
              "name": "description",
              "selector": ".we-truncate__text, .section__description, p.whats-new__description",
              "post_processing": [
                "collapse_whitespace"
              ]
            },
            {
              "name": "latest_version",
              "selector": "p.whats-new__latest__version, .version-history__item__version-number, #mostRecentVersion h3",
              "post_processing": [
                "collapse_whitespace"
              ]
            },
            {
              "name": "rating_count",
              "selector": "#productRatings .we-customer-ratings__count, #productRatings .we-rating-count, #productRatings [class*='rating-count']",
              "post_processing": [
                "collapse_whitespace"
              ]
            },
            {
              "name": "rating_summary_text",
              "selector": "#productRatings .we-customer-ratings__averages__display, #productRatings .we-star-rating, #productRatings",
              "post_processing": [
                "collapse_whitespace"
              ]
            },
            {
              "name": "see_all_reviews_href",
              "selector": "a[href*='see-all=reviews']",
              "attribute": "href"
            }
          ]
        },
        "side_effects": [
          "read_only"
        ]
      },
      "name": "Extract core app metadata"
    },
    {
      "id": "s8",
      "action": {
        "kind": "extract_structured_data",
        "inputs": {
          "item_selector": "#product_media_phone_ img, [id^='product_media_'] img, [id^='product_media_'] source",
          "limit": 20,
          "fields": [
            {
              "name": "src",
              "selector": "*",
              "attribute": "src"
            },
            {
              "name": "srcset",
              "selector": "*",
              "attribute": "srcset"
            },
            {
              "name": "alt",
              "selector": "*",
              "attribute": "alt"
            }
          ]
        },
        "side_effects": [
          "read_only"
        ]
      },
      "name": "Extract screenshot sources"
    },
    {
      "id": "s9",
      "action": {
        "kind": "extract_structured_data",
        "inputs": {
          "item_selector": "#allProductReviews .shelf-grid__list-item:not(.placeholder), #allProductReviews article",
          "limit": 20,
          "fields": [
            {
              "name": "title",
              "selector": "h1, h2, h3",
              "post_processing": [
                "collapse_whitespace"
              ]
            },
            {
              "name": "author",
              "selector": ".header-container .multiline-clamp, .content-modal-container .multiline-clamp, .review-header .multiline-clamp, .we-customer-review__user",
              "post_processing": [
                "collapse_whitespace"
              ]
            },
            {
              "name": "date",
              "selector": "time, [datetime], .we-customer-review__date",
              "attribute": "datetime"
            },
            {
              "name": "date_text",
              "selector": "time, .we-customer-review__date",
              "post_processing": [
                "collapse_whitespace"
              ]
            },
            {
              "name": "body",
              "selector": ".content, blockquote, .we-clamp, .content-modal-container .content, .we-customer-review__body",
              "post_processing": [
                "collapse_whitespace"
              ]
            },
            {
              "name": "rating_aria",
              "selector": "[aria-label*='out of'], [aria-label*='stars']",
              "attribute": "aria-label"
            }
          ]
        },
        "side_effects": [
          "read_only"
        ]
      },
      "name": "Extract reviews visible on product page"
    },
    {
      "id": "s10",
      "action": {
        "kind": "execute_javascript",
        "inputs": {
          "world": "main",
          "script": "const cleanArg = (v) => { const t = String(v == null ? '' : v).trim(); return /^\\{[a-zA-Z0-9_]+\\}$/.test(t) ? '' : t; };\nconst mode = cleanArg('{mode}').toLowerCase() || 'with-reviews';\nif (mode !== 'full') { return { skipped: true, mode }; }\nconst link = document.querySelector(\"a[href*='see-all=reviews']\");\nif (!link) { return { skipped: true, reason: 'no see-all link' }; }\nconst target = link.href;\nsetTimeout(() => window.location.assign(target), 0);\nreturn { redirected: true, target, mode };",
          "return_value": true
        },
        "side_effects": [
          "browser_state"
        ]
      },
      "name": "[mode=full] Open the full Ratings & Reviews page"
    },
    {
      "id": "s11",
      "action": {
        "kind": "wait_for_timeout",
        "inputs": {},
        "side_effects": [
          "read_only"
        ]
      },
      "name": "[mode=full] Wait for full review page hydration",
      "timeout_ms": 4000
    },
    {
      "id": "s12",
      "action": {
        "kind": "extract_structured_data",
        "inputs": {
          "item_selector": "article:has(h1), article:has(h2), article:has(h3), .we-customer-review",
          "limit": 50,
          "fields": [
            {
              "name": "title",
              "selector": "h1, h2, h3",
              "post_processing": [
                "collapse_whitespace"
              ]
            },
            {
              "name": "author",
              "selector": ".review-header p, .review-header span, .review-header [class*='truncate'], .we-customer-review__user",
              "post_processing": [
                "collapse_whitespace"
              ]
            },
            {
              "name": "date",
              "selector": "time, [datetime], .we-customer-review__date",
              "attribute": "datetime"
            },
            {
              "name": "date_text",
              "selector": "time, .we-customer-review__date",
              "post_processing": [
                "collapse_whitespace"
              ]
            },
            {
              "name": "body",
              "selector": "blockquote, .we-clamp, .we-customer-review__body, .content",
              "post_processing": [
                "collapse_whitespace"
              ]
            },
            {
              "name": "rating_aria",
              "selector": "[aria-label*='out of'], [aria-label*='stars']",
              "attribute": "aria-label"
            }
          ]
        },
        "side_effects": [
          "read_only"
        ]
      },
      "name": "[mode=full] Extract full review rows"
    }
  ],
  "result": {
    "artifact_policy": {
      "prefer_downloads": false
    },
    "include_debug": false,
    "output_schema": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "author": {
            "type": "string"
          },
          "date": {
            "type": "string"
          },
          "date_text": {
            "type": "string"
          },
          "body": {
            "type": "string"
          },
          "rating_aria": {
            "type": "string"
          }
        }
      }
    },
    "output_selector": {
      "step_id": "s12",
      "path": "$"
    }
  },
  "help": {
    "summary": "Open one App Store app page; return metadata, screenshots, and reviews.",
    "parameters": {
      "app_id": "Numeric App Store app id. Either this or app_url must be given.",
      "app_url": "Full App Store URL. Overrides app_id when both are set.",
      "country": "Two-letter storefront code. Used only when constructing the URL from app_id. Defaults to 'us'.",
      "mode": "with-reviews (default) = metadata + screenshots + on-page reviews; full = also opens /see-all=reviews for a deeper review batch. 'basic' is accepted as an alias of with-reviews."
    },
    "examples": [
      {
        "command": "rzn-browser run appstore app-details --param app_id=\"1232780281\"",
        "description": "Notion \u2014 US, with the on-page reviews (default mode)."
      },
      {
        "command": "rzn-browser run appstore app-details --param app_url=\"https://apps.apple.com/gb/app/notion/id1232780281\" --param mode=\"full\"",
        "description": "UK page, deep review mode."
      },
      {
        "command": "rzn-browser run appstore app-details --param app_id=\"1232780281\"",
        "description": "Default with-reviews mode: metadata + screenshots + on-page reviews."
      }
    ],
    "returns": [
      "Object with app metadata (title/subtitle/category/description/version/ratings), screenshot array (src/srcset/alt), and review array (title/author/date/body/rating_aria). In full mode the full-page review array is additionally included."
    ],
    "notes": [
      "Read-only.",
      "Either app_id or app_url must be supplied; if both are set, app_url wins.",
      "The product page is React/Svelte-rendered; we rely on IDs (`#productRatings`, `#allProductReviews`, `#product_media_phone_`) which have been stable across Apple's redesigns.",
      "`rating_aria` carries the '4.5 out of 5 stars' accessibility label \u2014 that's the most reliable numeric rating read.",
      "`mode=full` incurs an extra page navigation and ~4s wait."
    ]
  },
  "metadata": {
    "migrated_from": "appstore/app-details.json",
    "legacy_system_id": "appstore"
  }
}
